{
  "name": "orca",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.7",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "build": "bun build ./apps/cli/src/cli.ts --outfile ./dist/orca --target bun",
    "check": "bunx tsc --noEmit",
    "test": "bunx vitest run",
    "orca": "bun run ./apps/cli/src/cli.ts"
  },
  "devDependencies": {
    "@effect/vitest": "4.0.0-beta.29",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
